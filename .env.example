# Copy to .env and fill. Blank optional keys fall back to safe dev behavior.

# --- Core ---
NEXTAUTH_URL=http://localhost:3000          # prod: https://paply.me
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXT_PUBLIC_BASE_URL=http://localhost:3000  # prod: https://paply.me
NEXT_PUBLIC_APP_NAME=paply
DATABASE_URL=file:./dev.db  # prod: postgresql://...

# --- Google OAuth ("Connect Gmail" + sign-in) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Scopes: openid, email, profile, https://www.googleapis.com/auth/gmail.send
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Until verified, keep the OAuth app in "Testing" mode (≤100 test users).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI generation (provider-agnostic; all blank → smart multilingual template) ---
# Two tiers. FREE tier (every user) runs on a CHAIN of free-but-smart, fast, OpenAI-compatible
# providers. Every slot you fill in is tried in order — if one is down, rate-limited, or slow
# (14s timeout), the next one takes over automatically. Fill in as many as you like; the first
# one that answers wins, so there's no extra cost or latency on the happy path.
#
# Recommended free options (all offer a genuinely free tier — pick 2-4 for real resilience):
#   Groq     → BASE_URL=https://api.groq.com/openai/v1                          MODEL=llama-3.3-70b-versatile   (fastest — sub-second)
#   Gemini   → BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai MODEL=gemini-2.0-flash          (fast, strong reasoning)
#   Cerebras → BASE_URL=https://api.cerebras.ai/v1                              MODEL=llama-3.3-70b             (fastest inference hardware)
#   OpenRouter (free models) → BASE_URL=https://openrouter.ai/api/v1  MODEL=meta-llama/llama-3.3-70b-instruct:free (or any ":free" model)
#   Self-hosted Ollama       → BASE_URL=http://localhost:11434/v1     MODEL=llama3.3 (needs no API key at all — set API_KEY to any non-empty string)
FREE_AI_BASE_URL=
FREE_AI_API_KEY=
FREE_AI_MODEL=
# Additional providers in the same chain — fill in 1..6 of these, any mix of the options above:
FREE_AI_1_BASE_URL=
FREE_AI_1_API_KEY=
FREE_AI_1_MODEL=
FREE_AI_2_BASE_URL=
FREE_AI_2_API_KEY=
FREE_AI_2_MODEL=
FREE_AI_3_BASE_URL=
FREE_AI_3_API_KEY=
FREE_AI_3_MODEL=

# PRO tier (paid users): premium model. Native Anthropic…
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# …or any other OpenAI-compatible premium provider instead of Anthropic:
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# Notes: if only one of the above is set, both tiers use it and fall back to each other's
# providers as a last resort, so a single configured key still works everywhere.

# --- Security ---
TOKEN_ENC_KEY=              # 32+ char secret to encrypt stored OAuth tokens

# --- SMTP fallback (Gmail App Password) — OWNER-ONLY ---
# Security: this is a single shared credential. The send route only uses it when the
# signed-in, Google-verified address EQUALS SMTP_USER. It can never send for other users.
# Leave SMTP_USER blank to disable this path entirely (recommended in multi-tenant prod).
SMTP_USER=
SMTP_APP_PASSWORD=

# --- Stripe (optional; blank → stub billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_ENABLED=false

# --- Limits ---
FREE_MONTHLY_LIMIT=15

# --- Admin ---
# Comma-separated exact emails that get admin (unlimited) access via Google OAuth only.
# Demo/credentials logins never get admin status regardless of email.
ADMIN_EMAILS=
# Comma-separated domains: every @domain.com address signed in via Google becomes admin.
ADMIN_DOMAINS=
# Comma-separated emails that are automatically granted pro plan on sign-in (owner accounts).
# GREATEST() logic ensures Stripe-paid plans are never downgraded by this list.
PRO_EMAILS=
