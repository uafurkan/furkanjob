# Copy to .env and fill. Blank optional keys fall back to safe dev behavior.

# --- Core ---
NEXTAUTH_URL=http://localhost:3000          # prod: https://paply.me
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXT_PUBLIC_BASE_URL=http://localhost:3000  # prod: https://paply.me
NEXT_PUBLIC_APP_NAME=paply
DATABASE_URL=file:./dev.db  # prod: postgresql://...

# --- Google OAuth ("Connect Gmail" + sign-in) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Scopes: openid, email, profile, https://www.googleapis.com/auth/gmail.send
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Until verified, keep the OAuth app in "Testing" mode (≤100 test users).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI generation (provider-agnostic; all blank → smart multilingual template) ---
# Two tiers. FREE tier (every user) runs on a free-but-smart, OpenAI-compatible provider.
# Recommended free options (pick one, paste its key):
#   Groq    → FREE_AI_BASE_URL=https://api.groq.com/openai/v1   FREE_AI_MODEL=llama-3.3-70b-versatile
#   Gemini  → FREE_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai  FREE_AI_MODEL=gemini-2.0-flash
#   Cerebras→ FREE_AI_BASE_URL=https://api.cerebras.ai/v1       FREE_AI_MODEL=llama-3.3-70b
FREE_AI_BASE_URL=
FREE_AI_API_KEY=
FREE_AI_MODEL=

# PRO tier (paid users): premium model. Native Anthropic…
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# …or any other OpenAI-compatible premium provider instead of Anthropic:
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
# Notes: if only one of the above is set, both tiers use it. Self-hosting? Point FREE_AI_BASE_URL
# at a local Ollama (http://localhost:11434/v1) for a fully free, self-hosted brain.

# --- Security ---
TOKEN_ENC_KEY=              # 32+ char secret to encrypt stored OAuth tokens

# --- SMTP fallback (Gmail App Password; dev/testing only) ---
SMTP_USER=
SMTP_APP_PASSWORD=

# --- Stripe (optional; blank → stub billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_ENABLED=false

# --- Limits ---
FREE_MONTHLY_LIMIT=15

# --- Admin ---
# Comma-separated emails allowed to access /admin (e.g. you@paply.me)
ADMIN_EMAILS=
