# Bu dosyayı .env olarak kopyala ve doldur.

# Gönderen Gmail adresi
GMAIL_USER=furkanhulakojob@gmail.com

# Gmail App Password (16 haneli). Nasıl alınır:
# 1) Google Hesabı > Güvenlik > 2 Adımlı Doğrulama'yı AÇ
# 2) https://myaccount.google.com/apppasswords adresine git
# 3) "Uygulama şifresi" oluştur, çıkan 16 haneli kodu boşluksuz buraya yapıştır
GMAIL_APP_PASSWORD=

# CV dosya yolu (varsayılan: cv/cv.pdf). Kendi CV'ni cv/cv.pdf olarak koy.
CV_PATH=

# (Opsiyonel) Claude API ile her işletmeye özgün taslak için.
# Boş bırakırsan akıllı şablon kullanılır.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Port (opsiyonel)
PORT=3000
