# Copy to .env and fill. Blank optional keys fall back to safe dev behavior.

# --- Core ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # openssl rand -base64 32
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=paply
DATABASE_URL=file:./dev.db  # prod: postgresql://...

# --- Google OAuth ("Connect Gmail" + sign-in) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Scopes: openid, email, profile, https://www.googleapis.com/auth/gmail.send
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Until verified, keep the OAuth app in "Testing" mode (≤100 test users).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI generation (optional; blank → smart template) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Security ---
TOKEN_ENC_KEY=              # 32+ char secret to encrypt stored OAuth tokens

# --- SMTP fallback (Gmail App Password; dev/testing only) ---
SMTP_USER=
SMTP_APP_PASSWORD=

# --- Stripe (optional; blank → stub billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_ENABLED=false

# --- Limits ---
FREE_MONTHLY_LIMIT=15

# --- Admin ---
# Comma-separated emails allowed to access /admin (e.g. you@paply.app)
ADMIN_EMAILS=
